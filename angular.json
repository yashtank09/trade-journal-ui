{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "packageManager": "npm",
    "analytics": false,
    "defaultCollection": "@angular-eslint/schematics"
  },
  "newProjectRoot": "projects",
  "projects": {
    "trade-journal-ui": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss",
          "standalone": true,
          "inlineStyle": false,
          "inlineTemplate": false
        },
        "@schematics/angular:class": {
          "skipTests": true
        },
        "@schematics/angular:directive": {
          "skipTests": true,
          "standalone": true
        },
        "@schematics/angular:guard": {
          "skipTests": true
        },
        "@schematics/angular:interceptor": {
          "skipTests": true
        },
        "@schematics/angular:pipe": {
          "skipTests": true,
          "standalone": true
        },
        "@schematics/angular:resolver": {
          "skipTests": true
        },
        "@schematics/angular:service": {
          "skipTests": true
        }
      },
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "browser": "src/main.ts",
            "tsConfig": "tsconfig.app.json",
            "inlineStyleLanguage": "scss",
            "assets": [
              {
                "glob": "**/*",
                "input": "public"
              },
              {
                "glob": "**/*",
                "input": "src/assets"
              }
            ],
            "styles": [
              "src/styles.scss"
            ],
            "scripts": [],
            "allowedCommonJsDependencies": [
              "lodash",
              "moment",
              "chart.js"
            ]
          },
          "configurations": {
            "production": {
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.prod.ts"
                }
              ],
              "optimization": {
                "scripts": true,
                "styles": {
                  "minify": true,
                  "inlineCritical": false
                },
                "fonts": true
              },
              "outputHashing": "all",
              "sourceMap": false,
              "extractLicenses": true,
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "2MB",
                  "maximumError": "5MB",
                  "baseline": "500kB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "16kB",
                  "maximumError": "32kB"
                },
                {
                  "type": "bundle",
                  "maximumWarning": "4MB",
                  "maximumError": "8MB"
                },
                {
                  "type": "all",
                  "maximumWarning": "6MB",
                  "maximumError": "10MB"
                }
              ],
              "namedChunks": false,
              "aot": true,
              "strict": true,
              "preserveSymlinks": false,
              "subresourceIntegrity": true,
              "serviceWorker": true,
              "ngswConfigPath": "ngsw-config.json"
            },
            "development": {
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.development.ts"
                }
              ],
              "optimization": {
                "scripts": false,
                "styles": {
                  "minify": false,
                  "inlineCritical": false
                },
                "fonts": false
              },
              "sourceMap": true,
              "extractLicenses": false,
              "aot": false,
              "namedChunks": true,
              "preserveSymlinks": true,
              "watch": true,
              "poll": 1000
            },
            "staging": {
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.staging.ts"
                }
              ],
              "optimization": {
                "scripts": true,
                "styles": {
                  "minify": true,
                  "inlineCritical": true
                },
                "fonts": true
              },
              "outputHashing": "media",
              "sourceMap": true,
              "extractLicenses": true,
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "3MB",
                  "maximumError": "6MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "20kB",
                  "maximumError": "40kB"
                }
              ],
              "namedChunks": true,
              "extractLicenses": true,
              "aot": true,
              "strict": true,
              "preserveSymlinks": false,
              "subresourceIntegrity": false
            },
            "local": {
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.local.ts"
                }
              ],
              "optimization": {
                "scripts": false,
                "styles": {
                  "minify": false,
                  "inlineCritical": false
                },
                "fonts": false
              },
              "sourceMap": true,
              "extractLicenses": false,
              "aot": false,
              "namedChunks": true,
              "preserveSymlinks": true,
              "watch": true,
              "poll": 500,
              "liveReload": true,
              "hmr": true,
              "port": 4200,
              "host": "localhost"
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "options": {
            "buildTarget": "trade-journal-ui:build",
            "port": 4200,
            "host": "localhost",
            "open": true,
            "ssl": false,
            "sslKey": "",
            "sslCert": "",
            "proxyConfig": ""
          },
          "configurations": {
            "production": {
              "buildTarget": "trade-journal-ui:build:production",
              "ssl": false,
              "liveReload": false,
              "hmr": false
            },
            "development": {
              "buildTarget": "trade-journal-ui:build:development",
              "liveReload": true,
              "hmr": true,
              "watch": true
            },
            "staging": {
              "buildTarget": "trade-journal-ui:build:staging",
              "ssl": false,
              "liveReload": false,
              "hmr": false
            },
            "local": {
              "buildTarget": "trade-journal-ui:build:local",
              "liveReload": true,
              "hmr": true,
              "watch": true,
              "open": true
            }
          },
          "defaultConfiguration": "development"
        },
        "extract-i18n": {
          "builder": "@angular/build:extract-i18n",
          "options": {
            "buildTarget": "trade-journal-ui:build"
          }
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "tsConfig": "tsconfig.spec.json",
            "polyfills": [
              "zone.js",
              "zone.js/testing"
            ],
            "assets": [
              {
                "glob": "**/*",
                "input": "public"
              }
            ],
            "styles": [
              "src/styles.scss"
            ],
            "scripts": [],
            "watch": false,
            "codeCoverage": true,
            "codeCoverageExclude": [
              "**/node_modules/**",
              "**/dist/**",
              "**/testing/**"
            ],
            "reporters": [
              "default",
              "html",
              "json-summary"
            ],
            "browsers": [
              "ChromeHeadless"
            ],
            "webServerConfig": {
              "target": "http://localhost:4200"
            }
          }
        },
        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": {
            "lintFilePatterns": [
              "src/**/*.ts",
              "src/**/*.html"
            ],
            "exclude": [
              "**/node_modules/**",
              "**/dist/**"
            ],
            "maxWarnings": 0,
            "fix": true,
            "format": "stylish",
            "force": true,
            "quiet": false
          }
        },
        "e2e": {
          "builder": "@angular/build:protractor",
          "options": {
            "protractorConfig": "e2e/protractor.conf.js",
            "devServerTarget": "trade-journal-ui:serve"
          },
          "configurations": {
            "production": {
              "devServerTarget": "trade-journal-ui:serve:production"
            },
            "ci": {
              "protractorConfig": "e2e/protractor-ci.conf.js"
            }
          }
        }
      }
    }
  }
}
