{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "assetGroups": [
    {
      "name": "app",
      "installMode": "prefetch",
      "resources": {
        "files": [
          "/favicon.ico",
          "/index.html",
          "/manifest.webmanifest",
          "/*.css",
          "/*.js"
        ]
      }
    },
    {
      "name": "assets",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/assets/**",
          "/*.(svg|cur|jpg|png|webp|avif|gif|otf|ttf|woff|woff2)"
        ]
      }
    }
  ],
  "dataGroups": [
    {
      "name": "api-freshness",
      "cacheConfigs": [
        {
          "url": "/api/**",
          "cacheability": "freshness",
          "maxAge": "1h",
          "maxSize": 100,
          "strategy": "freshness",
          "timeout": "5s"
        }
      ]
    },
    {
      "name": "api-performance",
      "cacheConfigs": [
        {
          "url": "/api/config/**",
          "cacheability": "performance",
          "maxAge": "7d",
          "maxSize": 10,
          "strategy": "performance"
        }
      ]
    }
  ],
  "navigationUrls": [
    "/**",
    "!/**/*.[*]",
    "!/**/*__*",
    "!/**/*__*/**",
    "!/**/_*"
  ]
}
